<nav class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container-fluid px-4">
    <%= link_to "Git Analyzer", root_path, class: "navbar-brand fw-bold" %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
            aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarContent">
      <% if user_signed_in? %>
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <%= link_to 'Dashboard', root_path, class: "nav-link" %>
          </li>
        </ul>

        <!-- Search and Sign out section aligned vertically -->
        <div class="d-flex align-items-center ms-auto gap-3">
          <!-- Search bar -->
          <form class="d-flex align-items-center" role="search" action="<%= root_path %>" method="get">
            <input class="form-control me-2" type="search" name="query" placeholder="Search Employee" aria-label="Search">
            <button class="btn btn-outline-light" type="submit">Search</button>
          </form>

          <!-- Sign Out Button -->
          <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                class: "btn btn-outline-danger px-3" %>
        </div>

      <% else %>
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">&nbsp;</li>
        </ul>

        <div class="d-flex ms-auto align-items-center">
          <%= link_to "Login", new_user_session_path, class: "btn btn-outline-primary px-3 me-2" %>
          <%= link_to "Sign up", new_user_registration_path, class: "btn btn-outline-danger px-3" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
