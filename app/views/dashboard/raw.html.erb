<h1 class="mb-4">Raw Data</h1>

<div class="card mb-5">
  <div class="card-header">
    <h2>Employees</h2>
  </div>
  <div class="card-body table-responsive" style="max-height: 600px; overflow-y: auto;">
    <table class="table table-striped table-bordered table-hover">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>GitHub ID</th>
          <th>Dev Score</th>
          <th>Review Score</th>
          <th>Merge Speed</th>
          <th>Churn</th>
          <th>Quality</th>
          <th>Feedback Response</th>
          <th>Coverage</th>
          <th>Review Time</th>
          <th>Closing Speed</th>
          <th>Engagement</th>
        </tr>
        <% @employees.each do |emp| %>
          <tr>
            <td><%= emp.id %></td>
            <td><%= emp.name %></td>
            <td><%= emp.github_id %></td>
            <td><%= emp.dev_score&.round(2) || 0%></td>
            <td><%= emp.rev_score&.round(2) || 0 %></td>
            <td><%= emp.merge_speed&.round(2) || 0 %></td>
            <td><%= emp.churn_score&.round(2) || 0 %></td>
            <td><%= emp.code_quality&.round(2) || 0 %></td>
            <td><%= emp.response_to_feedback&.round(2) || 0 %></td>
            <td><%= emp.review_coverage&.round(2) || 0 %></td>
            <td><%= emp.response_time&.round(2) || 0 %></td>
            <td><%= emp.closing_speed&.round(2) || 0 %></td>
            <td><%= emp.engagement_score&.round(2) || 0 %></td>
          </tr>
        <% end %>
    </table>
  </div>
</div>


<div class="card mb-5">
  <div class="card-header">
    <h2>Pull Requests</h2>
  </div>
  <div class="card-body table-responsive" style="max-height: 600px; overflow-y: auto;">
    <table class="table table-striped table-bordered table-hover">
        <tr>
          <th>ID</th>
          <th>PR ID</th>
          <th>Node ID</th>
          <th>Status</th>
          <th>Created</th>
          <th>Merged</th>
          <th>Closed</th>
          <th>LOC</th>
          <th>Reviews</th>
        </tr>
        <% @pull_requests.each do |pr| %>
          <tr>
            <td><%= pr.id %></td>
            <td><%= pr.pr_id %></td>
            <td><%= pr.pr_node_id %></td>
            <td><%= pr.status %></td>
            <td><%= pr.pr_created_at.strftime("%b %d, %Y") %></td>
            <td><%= pr.pr_merged_at&.strftime("%b %d, %Y") %></td>
            <td><%= pr.pr_closed_at&.strftime("%b %d, %Y") %></td>
            <td><%= pr.LOC %></td>
            <td><%= pr.review_counts %></td>
          </tr>
        <% end %>
    </table>
  </div>
</div>

<div class="card mb-5">
  <div class="card-header">
    <h2>Reviews</h2>
  </div>
  <div class="card-body table-responsive" style="max-height: 600px; overflow-y: auto;">
    <table class="table table-striped table-bordered table-hover">
        <tr>
          <th>ID</th>
          <th>Review ID</th>
          <th>Node ID</th>
          <th>GitHub ID</th>
          <th>PR ID</th>
          <th>Created</th>
          <th>Next Commit</th>
        </tr>
        <% @reviews.each do |rev| %>
          <tr>
            <td><%= rev.id %></td>
            <td><%= rev.review_id %></td>
            <td><%= rev.review_node_id %></td>
            <td><%= rev.github_id %></td>
            <td><%= rev.pr_id %></td>
            <td><%= rev.rev_created_at.strftime("%b %d, %Y %H:%M") %></td>
            <td><%= rev.next_commit_at&.strftime("%b %d, %Y %H:%M") %></td>
          </tr>
        <% end %>
    </table>
  </div>
</div>

<div class="card mb-5">
  <div class="card-header">
    <h2>Developer Matrix</h2>
  </div>
  <div class="card-body table-responsive" style="max-height: 600px; overflow-y: auto;">
    <table class="table table-striped table-bordered table-hover" style="min-width: max-content;">
        <tr>
          <th>ID</th>
          <th>PR ID</th>
          <th>GitHub ID</th>
          <th>LOC</th>
          <th>Created</th>
        </tr>
        <% @dev_matrices.each do |dm| %>
          <tr>
            <td><%= dm.id %></td>
            <td><%= dm.pr_id %></td>
            <td><%= dm.github_id %></td>
            <td><%= dm.LOC %></td>
            <td><%= dm.created_at.strftime("%b %d, %Y") %></td>
          </tr>
        <% end %>
    </table>
  </div>
</div>
