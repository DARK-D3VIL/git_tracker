<%= form_with url: dashboard_index_path, method: :get, class: "mb-4" do |f| %>
  <div class="row mb-3">
    <div class="col-md-4">
      <%= f.label :range, "Time Range:", class: "form-label" %>
      <%= f.select :range, [["All Time", "all"], ["Last 7 Days", "7days"], ["Last 30 Days", "30days"]], {}, class: "form-select" %>
    </div>
    
    <div class="col-md-4">
      <%= f.label :status, "PR Status:", class: "form-label" %>
      <%= f.select :status, [["All", "all"], ["Closed", "closed"]], {}, class: "form-select" %>
    </div>
    
    <div class="col-md-4">
      <%= f.label :sort_by, "Sort By:", class: "form-label" %>
      <%= f.select :sort_by, [["Development Score", "dev_score"], ["Review Score", "rev_score"]], {}, class: "form-select" %>
    </div>
  </div>
  
  <div class="text-center">
    <%= f.submit "Apply", class: "btn btn-secondary btn-sm" %>
  </div>
<% end %>

<div class="text-center my-4">
  <%= button_to 'View Raw Data', dashboard_raw_path,  method: :get,class: "btn btn-secondary btn-sm" %>
</div>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th scope="col">Name</th>
      <th scope="col">Github ID</th>
      <th scope="col">Dev Score</th>
      <th scope="col">Review Score</th>
      <th scope="col">View</th>
    </tr>
  </thead>
    <% @employees.each do |emp| %>
      <tr>
        <td><%= emp.name %></td>
        <td><%= emp.github_id %></td>
        <td><%= emp.dev_score.round(2) %></td>
        <td><%= emp.rev_score.round(2) %></td>
        <td><%= button_to "View Metrics", dashboard_show_path(emp.id), method: :get, class: "btn btn-secondary btn-sm" %></td>
      </tr>
    <% end %>
</table>
