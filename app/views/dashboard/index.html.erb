<%= form_with url: dashboard_index_path, method: :get, class: "mb-4" do |f| %>
  <div class="row mb-3">
    <div class="col-md-4">
      <%= f.label :range, "Time Range:", class: "form-label" %>
      <%= f.select :range, [["All Time", "all"], ["Last 7 Days", "7days"], ["Last 30 Days", "30days"]], selected: params[:range], class: "form-select" %>
    </div>

    <div class="col-md-4">
      <%= f.label :status, "PR Status:", class: "form-label" %>
      <%= f.select :status, [["All", "all"], ["Closed", "closed"]], selected: params[:status], class: "form-select" %>
    </div>

    <div class="col-md-4">
      <%= f.label :sort_by, "Sort By:", class: "form-label" %>
      <%= f.select :sort_by, [["Development Score", "dev_score"], ["Review Score", "rev_score"]], selected: params[:sort_by], class: "form-select" %>
    </div>
  </div>

  <div class="text-center">
    <%= f.submit "Apply", class: "btn btn-secondary btn-sm" %>
  </div>
<% end %>


<table class="table table-striped table-bordered">
  <tr>
    <th scope="col">Name</th>
    <th scope="col">Development Performance Score</th>
    <th scope="col">Reviewer Performance Score</th>
    <th scope="col">View</th>
  </tr>
  <% @employees.each do |emp| %>
    <tr>
      <td><%= link_to emp.name, "https://github.com/#{emp.name}", target: "_blank", rel: "noopener" %></td>
      <td><%= emp.dev_score.round(2) %></td>
      <td><%= emp.rev_score.round(2) %></td>
      <td><%= button_to "View Metrics", dashboard_show_path(emp.id), params: {range: params[:range], status: params[:status]}, method: :get, class: "btn btn-secondary btn-sm" %></td>
    </tr>
  <% end %>
</table>

