<h2 class="text-center text-dark mb-4">Change your password</h2>

<div class="d-flex justify-content-center align-items-center">
  <div class="card shadow-lg rounded-4 border-0 bg-white p-4" style="width: 400px;">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="mb-3">
        <%= f.label :password, "New password", class: "form-label fw-semibold text-dark" %>
        <% if @minimum_password_length %>
          <small class="text-muted d-block mb-2">(Minimum <%= @minimum_password_length %> characters)</small>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirm new password", class: "form-label fw-semibold text-dark" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="d-grid gap-2">
        <%= f.submit "Change my password", class: "btn btn-dark btn-lg" %>
      </div>
    <% end %>
  </div>
</div>

<div class="text-center mt-4">
  <%= render "devise/shared/links", class: "text-dark" %>
</div>
