<h2 class="text-center text-dark mb-3">Log In</h2>

<div class="d-flex justify-content-center align-items-center">
  <div class="card shadow-lg rounded-4 border-0 bg-white p-4" style="width: 400px;">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-3">
        <%= f.label :email, class: "form-label fw-semibold text-dark" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label fw-semibold text-dark" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-3 form-check">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, class: "form-check-label text-dark" %>
        </div>
      <% end %>

      <div class="d-grid gap-2">
        <%= f.submit "Log in", class: "btn btn-dark btn-lg" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Render Devise Links, including 'Forgot Password' -->
<div class="text-center mt-2">
  <%= render "devise/shared/links", class: "text-dark" %>
</div>
