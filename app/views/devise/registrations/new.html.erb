<h2 class="text-center text-dark mb-3">Sign Up</h2>

<div class="d-flex justify-content-center align-items-center">
  <div class="card shadow-lg rounded-4 border-0 bg-white p-4" style="width: 400px;">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-3">
        <%= f.label :email, class: "form-label fw-semibold text-dark" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label fw-semibold text-dark" %>
        <% if @minimum_password_length %>
          <small class="text-muted d-block mb-2">(Minimum <%= @minimum_password_length %> characters)</small>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, class: "form-label fw-semibold text-dark" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="d-grid gap-2">
        <%= f.submit "Sign up", class: "btn btn-dark btn-lg" %>
      </div>
    <% end %>
  </div>
</div>

<div class="text-center mt-2">
  <%= link_to "Already have an account? Log in here.", new_session_path(resource_name), class: "text-dark" %>
</div>
