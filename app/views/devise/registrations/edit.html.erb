<h2 class="text-center text-dark mb-4">Edit <%= resource_name.to_s.humanize %></h2>

<div class="d-flex justify-content-center align-items-center">
  <div class="card shadow-lg rounded-4 border-0 bg-white p-4" style="width: 400px;">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-3">
        <%= f.label :email, class: "form-label fw-semibold text-dark" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="alert alert-warning p-2">
          Currently waiting confirmation for: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :password, class: "form-label fw-semibold text-dark" %> 
        <i>(leave blank if you don't want to change it)</i><br />
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
        <% if @minimum_password_length %>
          <small class="text-muted d-block mb-2">(Minimum <%= @minimum_password_length %> characters)</small>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, class: "form-label fw-semibold text-dark" %><br />
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="mb-3">
        <%= f.label :current_password, class: "form-label fw-semibold text-dark" %> 
        <i>(we need your current password to confirm your changes)</i><br />
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control bg-light text-dark border-0 rounded-3" %>
      </div>

      <div class="d-grid gap-2">
        <%= f.submit "Update", class: "btn btn-dark btn-lg" %>
      </div>
    <% end %>
  </div>
</div>

<h3 class="text-center mt-4 text-dark">Cancel my account</h3>

<div class="text-center">
  <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-danger btn-sm" %>
</div>

<div class="text-center mt-3">
  <%= link_to "Back", :back, class: "text-dark" %>
</div>
